# ═══════════════════════════════════════════
# WEBISAFE BACKEND — Variables d'environnement
# ═══════════════════════════════════════════
# Copie ce fichier en .env.local et remplis les vraies valeurs.
# Ne commit JAMAIS .env.local sur GitHub.

# ── Port du serveur Express ───────────────────────────────
PORT=3001

# ── Google PageSpeed Insights ─────────────────────────────
# Obtenir sur : console.cloud.google.com → "PageSpeed Insights API"
# Gratuit : 25 000 requêtes/jour
GOOGLE_PAGESPEED_KEY=your_google_pagespeed_key_here

# ── VirusTotal ────────────────────────────────────────────
# Obtenir sur : virustotal.com → Compte → "API Key"
# Gratuit : 500 requêtes/jour
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Environnement ─────────────────────────────────────────
NODE_ENV=development
