# ───────────────────────────────────────────────────────────────────────────
# WEBISAFE — Variables d'environnement
# Copiez ce fichier en .env (ou .env.local) et remplissez vos valeurs.
# Toutes les clés VITE_* sont exposées au frontend (build).
# Toutes les autres restent côté serveur (Vercel functions).
# ───────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite/React) ────────────────────────────────────────────────
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx
VITE_PUBLIC_APP_URL=https://webisafe.vercel.app

# ── Wave Checkout API (paiements automatisés) ────────────────────────
# Obtenir dans Wave Business Portal → Developers → API Keys
# WAVE_API_KEY      : clé secrète (Bearer) pour créer des sessions Checkout
# WAVE_SIGNING_SECRET : secret HMAC pour signer les requêtes sortantes (optionnel)
# WAVE_WEBHOOK_SECRET : secret HMAC pour vérifier les webhooks entrants (obligatoire en prod)
# Enregistrer l'URL webhook dans Wave Business Portal → Developers → Webhooks :
#   https://webisafe.vercel.app/api/webhook/wave
#   Événements : checkout.session.completed, checkout.session.payment_failed
WAVE_API_KEY=wave_sn_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WAVE_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WAVE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Performance scanner (Google PageSpeed) ───────────────────────────────
GOOGLE_PAGESPEED_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAGESPEED_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sécurité — VirusTotal (malware/réputation URL) ───────────────────────
VIRUSTOTAL_API_KEY=fdaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_VIRUSTOTAL_API_KEY=fdaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sécurité avancée — Google Safe Browsing v4 (10 000 req/jour gratuit) ─
# Obtenir sur : https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFE_BROWSING_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alias historique (le code lit aussi cette variable en fallback) :
GOOGLE_SAFE_BROWSING_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GOOGLE_SAFE_BROWSING_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Backend (Service Role — NE JAMAIS exposer côté frontend) ────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (emails transactionnels) ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
PUBLIC_APP_URL=https://webisafe.vercel.app

# ───────────────────────────────────────────────────────────────────────────
# CHECKS DE SÉCURITÉ AVANCÉS (api/scanners/security-checks.js)
# ───────────────────────────────────────────────────────────────────────────
# Les 7 checks suivants sont exécutés à chaque scan :
#  1. Security Headers (CSP, HSTS, X-Frame-Options, X-Content-Type-Options,
#     Referrer-Policy, Permissions-Policy)
#  2. DNS SPF + DMARC (via Cloudflare DoH 1.1.1.1)
#  3. Fichiers sensibles exposés (.env, .git, backups, phpinfo…)
#  4. Panneaux d'administration exposés (wp-admin, phpmyadmin…)
#  5. Google Safe Browsing — REQUIERT GOOGLE_SAFE_BROWSING_API_KEY
#  6. HaveIBeenPwned (fuites de données par domaine) — pas de clé requise
#  7. Mixed Content (HTTPS chargeant des ressources HTTP)
#
# Si GOOGLE_SAFE_BROWSING_API_KEY est absente, le check 5 retourne
# status: 'error' sans faire échouer les autres checks.
# ───────────────────────────────────────────────────────────────────────────
