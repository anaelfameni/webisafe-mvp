# Variables d'environnement utilisées UNIQUEMENT par vitest (MODE=test).
# Ce fichier est chargé automatiquement par Vite quand MODE === 'test'.
#
# H.1 — Active le bypass de rôles agence/admin via emails de test
# (agence@test.com, admin@test.com, client@test.com). Effectif uniquement
# si DEV === true ET VITE_ENABLE_TEST_BYPASS === 'true'. En prod, ces deux
# conditions ne peuvent pas être vraies simultanément.
VITE_ENABLE_TEST_BYPASS=true
