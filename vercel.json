{
  "version": 2,
  "buildCommand": "tsc && vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/scan.js": {
      "memory": 1024,
      "maxDuration": 60,
      "regions": [
        "cpt1"
      ]
    },
    "api/subscribe.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/history/[user_id].js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/uptime/[user_id].js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/badge/[site_url].js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/subscriptions.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/confirm-subscription.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/reject-subscription.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/cron/monthly-scan.js": {
      "memory": 1024,
      "maxDuration": 60,
      "regions": ["cpt1"]
    },
    "api/cron/uptime-check.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/cron/alert-followup.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/monthly-scan",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/uptime-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/alert-followup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/monitor-check",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(js|css|woff2|png|jpg|jpeg|gif|svg|ico|webp|avif))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://api.resend.com https://www.clarity.ms; font-src 'self' https: data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/.env", "destination": "/404" },
    { "source": "/.env.local", "destination": "/404" },
    { "source": "/.env.production", "destination": "/404" },
    { "source": "/.git/(.*)", "destination": "/404" },
    { "source": "/.git", "destination": "/404" },
    { "source": "/wp-config.php.bak", "destination": "/404" },
    { "source": "/wp-config.bak", "destination": "/404" },
    { "source": "/backup.zip", "destination": "/404" },
    { "source": "/backup.sql", "destination": "/404" },
    { "source": "/phpinfo.php", "destination": "/404" },
    { "source": "/server-status", "destination": "/404" },
    { "source": "/.htpasswd", "destination": "/404" },
    { "source": "/wp-admin", "destination": "/404" },
    { "source": "/wp-login.php", "destination": "/404" },
    { "source": "/admin", "destination": "/404" },
    { "source": "/administrator", "destination": "/404" },
    { "source": "/phpmyadmin", "destination": "/404" },
    { "source": "/pma", "destination": "/404" },
    { "source": "/cpanel", "destination": "/404" },
    { "source": "/webmail", "destination": "/404" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!sitemap.xml|robots.txt).*)", "destination": "/index.html" }
  ]
}