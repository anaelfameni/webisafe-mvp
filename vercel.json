{
  "version": 2,
  "buildCommand": "tsc && vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/scan.js": {
      "memory": 1024,
      "maxDuration": 60,
      "regions": ["cpt1"]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
